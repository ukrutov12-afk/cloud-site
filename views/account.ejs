<%- include('partials/header', { pageTitle: 'Cloud — ' + t('account.title') }) %>
<%
  var locMap = { ru: 'ru-RU', uk: 'uk-UA', be: 'be-BY', en: 'en-GB' };
  var loc = locMap[lang] || 'ru-RU';
  function fdate(s){ try { return new Date(s).toLocaleString(loc, {day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}); } catch(e){ return s; } }
  // UID: из БД или стабильно выводим из id
  var uid = account.uid;
  if (!uid) { uid = 0; for (var i=0;i<account.id.length;i++) uid=(uid*31+account.id.charCodeAt(i))%90000; uid+=10000; }
  var role = admin ? t('account.role_admin') : t('account.role_user');
%>

<section class="section narrow profile">
  <h1 class="prof-title"><%= t('account.title') %></h1>
  <p class="prof-sub muted"><%= t('account.subtitle') %></p>

  <!-- юзер -->
  <div class="prof-user">
    <form action="/account/avatar" method="post" enctype="multipart/form-data" class="avatar-form">
      <label class="avatar-edit" title="<%= t('account.btn_avatar') %>">
        <span class="acc-avatar">
          <% if (account.avatar) { %><img src="<%= account.avatar %>" alt=""><% } else { %><%= (account.username||'C').charAt(0).toUpperCase() %><% } %>
        </span>
        <input type="file" name="avatar" accept="image/*" hidden onchange="this.form.submit()">
        <span class="avatar-cam">＋</span>
      </label>
    </form>
    <div>
      <div class="pu-name"><%= account.username %></div>
      <div class="muted small"><%= account.email %></div>
    </div>
  </div>

  <hr class="prof-hr">

  <!-- подписка -->
  <div class="prof-section-label crown"><%= t('account.subscription') %></div>
  <div class="sub-row">
    <% if (sub) { %>
      <div>
        <div class="sub-name">Cloud<% if (!sub.forever) { %> (<%= sub.daysLeft %> <%= t('account.days_short') %>)<% } %></div>
        <div class="muted small">
          <% if (sub.forever) { %><%= t('account.forever') %><% } else { %><%= t('account.until') %> <%= fdate(sub.until) %><% } %>
        </div>
      </div>
      <div class="sub-right">
        <span class="sub-status <%= sub.active ? 'on' : 'off' %>"><%= sub.active ? t('account.status_active') : t('account.status_expired') %></span>
        <a href="/buy" class="btn btn-primary sub-renew"><%= t('account.renew') %></a>
      </div>
    <% } else { %>
      <div><div class="sub-name muted"><%= t('account.no_sub') %></div></div>
      <div class="sub-right"><a href="/buy" class="btn btn-primary sub-renew"><%= t('nav.buy') %></a></div>
    <% } %>
  </div>

  <hr class="prof-hr">

  <!-- данные аккаунта -->
  <div class="prof-section-label gear"><%= t('account.data') %></div>
  <%
    var ico = {
      uid:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><path d="M4 9h16M4 15h16M10 4 8 20M16 4l-2 16"/></svg>',
      role: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.6-7 9-4-1.4-7-4.5-7-9V6z"/></svg>',
      login:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/></svg>',
      mail: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M4 7l8 6 8-6"/></svg>',
      cal:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 9h18M8 3v4M16 3v4"/></svg>',
      hwid: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"><rect x="3" y="4" width="18" height="12" rx="2"/><path d="M8 20h8M12 16v4"/></svg>'
    };
  %>
  <div class="data-list">
    <div class="data-row"><span class="dr-k"><i class="dr-i"><%- ico.uid %></i><%= t('account.uid') %></span><span class="dr-v"><%= uid %></span></div>
    <div class="data-row"><span class="dr-k"><i class="dr-i"><%- ico.role %></i><%= t('account.role') %></span><span class="dr-v"><%= role %><% if (admin) { %> <span class="admin-badge">ADMIN</span><% } %></span></div>
    <div class="data-row"><span class="dr-k"><i class="dr-i"><%- ico.login %></i><%= t('account.login') %></span><span class="dr-v"><%= account.username %></span></div>
    <div class="data-row"><span class="dr-k"><i class="dr-i"><%- ico.mail %></i><%= t('account.email') %></span><span class="dr-v"><%= account.email %></span></div>
    <div class="data-row"><span class="dr-k"><i class="dr-i"><%- ico.cal %></i><%= t('account.registered') %></span><span class="dr-v"><%= fdate(account.createdAt) %></span></div>
    <div class="data-row"><span class="dr-k"><i class="dr-i"><%- ico.hwid %></i><%= t('account.hwid') %></span><span class="dr-v mono"><%= account.hwid || ('— ' + t('account.hwid_none')) %></span></div>
  </div>

  <hr class="prof-hr">

  <!-- действия -->
  <div class="prof-actions">
    <a href="#" class="btn btn-ghost act-btn"><%= t('account.btn_download') %></a>
    <form action="/account/soon" method="post"><button class="btn btn-ghost act-btn"><%= t('account.btn_key') %></button></form>
    <button type="button" class="btn btn-ghost act-btn" id="passToggle"><%= t('account.btn_pass') %></button>
    <form action="/account/hwid/reset" method="post"><button class="btn btn-ghost act-btn"><%= t('account.btn_hwid') %></button></form>
    <form action="/account/soon" method="post"><button class="btn btn-ghost act-btn"><%= t('account.btn_freeze') %></button></form>
    <form action="/account/soon" method="post"><button class="btn btn-ghost act-btn"><%= t('account.btn_2fa') %></button></form>
  </div>

  <!-- смена пароля (скрытая форма) -->
  <div class="panel pass-panel" id="passPanel" style="display:none">
    <h3 class="panel-h"><%= t('account.pass_title') %></h3>
    <form action="/account/password" method="post" class="form">
      <label class="field"><span><%= t('account.cur_pass') %></span><input type="password" name="current" required></label>
      <label class="field"><span><%= t('account.new_pass') %></span><input type="password" name="password" minlength="6" required></label>
      <label class="field"><span><%= t('account.new_pass2') %></span><input type="password" name="password2" minlength="6" required></label>
      <div class="row-gap">
        <button type="submit" class="btn btn-primary"><%= t('account.save') %></button>
        <button type="button" class="btn btn-ghost" id="passCancel"><%= t('account.cancel') %></button>
      </div>
    </form>
  </div>
</section>

<script>
  var pt = document.getElementById('passToggle'), pp = document.getElementById('passPanel'), pc = document.getElementById('passCancel');
  if (pt) pt.addEventListener('click', function(){ pp.style.display = pp.style.display==='none'?'block':'none'; pp.scrollIntoView({behavior:'smooth',block:'center'}); });
  if (pc) pc.addEventListener('click', function(){ pp.style.display='none'; });
</script>

<%- include('partials/footer') %>
