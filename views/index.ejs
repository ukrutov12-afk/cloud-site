<%- include('partials/header', { pageTitle: 'Cloud Client — ' + t('nav.home') }) %>

<div class="hero-bg"></div>

<section class="hero">
  <div class="hero-content">
    <span class="badge"><%= t('hero.badge') %></span>
    <h1 class="hero-title"><%= t('hero.title') %></h1>
    <p class="hero-sub"><%= t('hero.subtitle') %></p>
    <div class="hero-cta">
      <a href="/buy" class="btn btn-primary btn-lg"><%= t('hero.cta_buy') %></a>
      <a href="/docs/terms" class="btn btn-ghost btn-lg"><%= t('hero.cta_docs') %></a>
    </div>
    <div class="hero-stats">
      <div><strong>12k+</strong><span><%= t('hero.stat_users') %></span></div>
      <div><strong>99.9%</strong><span><%= t('hero.stat_uptime') %></span></div>
      <div><strong>40+</strong><span><%= t('hero.stat_modules') %></span></div>
    </div>
  </div>
  <div class="hero-glass">
    <div class="glass-card">
      <div class="glass-head">
        <span class="dot"></span><span class="dot"></span><span class="dot"></span>
        <em>Cloud — Combat</em>
      </div>
      <div class="glass-rows">
        <div class="grow"><span>Attack Aura</span><i class="sw on"></i></div>
        <div class="grow"><span>Triggerbot</span><i class="sw"></i></div>
        <div class="grow"><span>Player ESP</span><i class="sw on"></i></div>
        <div class="grow"><span>Auto Totem</span><i class="sw on"></i></div>
        <div class="grow"><span>Fullbright</span><i class="sw"></i></div>
      </div>
    </div>
  </div>
</section>

<section class="features section has-shot" style="--shot:url('/img/sec1.jpg')">
  <h2 class="section-title"><%= t('features.title') %></h2>
  <div class="feature-grid">
    <%
      const icons = {
        f1: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.6 5.6L20.5 8.4l-4.3 4.1 1 6L12 15.8 6.8 18.5l1-6L3.5 8.4l5.9-.8z"/></svg>',
        f2: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.6-7 9-4-1.4-7-4.5-7-9V6z"/><path d="M9.5 12l1.8 1.8L15 9.8"/></svg>',
        f3: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18M8 4v5"/></svg>',
        f4: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7L21 8"/><path d="M21 4v4h-4"/></svg>'
      };
    %>
    <% ['f1','f2','f3','f4'].forEach(function(f){ %>
      <div class="feature-card">
        <div class="feature-ico"><%- icons[f] %></div>
        <h3><%= t('features.' + f + '_t') %></h3>
        <p><%= t('features.' + f + '_d') %></p>
      </div>
    <% }); %>
  </div>
</section>

<section class="section has-shot" style="--shot:url('/img/sec2.jpg')">
  <div class="cta-band">
    <div>
      <h2><%= t('hero.cta_buy') %></h2>
      <p class="muted"><%= t('pricing.subtitle') %></p>
    </div>
    <a href="/buy" class="btn btn-primary btn-lg"><%= t('nav.buy') %></a>
  </div>
</section>

<%- include('partials/footer') %>
